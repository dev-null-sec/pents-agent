# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node / frontend tooling
node_modules/
dist/
build/
.cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Logs and temporary files
*.log
*.tmp
tmp/
temp/
/outputs/
/raw/

# Local third-party tool runtime and build caches.
# Tool source/forks under tools/third-party/vendor/ are versioned when maintained by this project.
tools/third-party/bin/*
!tools/third-party/bin/README.md
tools/third-party/cache/
tools/third-party/dist/

# Pentest raw outputs and bulky captures
projects/*/raw/
projects/*/outputs/
projects/*/runs/*/raw/
projects/*/runs/*/outputs/
projects/**/*.har
projects/**/*.pcap
projects/**/*.pcapng
projects/**/*.zip
projects/**/*.7z
projects/**/*.tar
projects/**/*.gz

# Local reference archives are kept outside versioned project assets.
refer/*
!refer/README.md
