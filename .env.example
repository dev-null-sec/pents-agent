# Copy this file to .env or .env.local and fill local secrets there.
# Real env files are ignored by git.

PENTS_VISION_API_KEY=
PENTS_VISION_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
PENTS_VISION_MODEL=mimo-v2.5

# Optional. Official MiMo API examples use max_completion_tokens.
# token-plan-cn currently works with the default max_tokens.
PENTS_VISION_TOKEN_PARAM=
